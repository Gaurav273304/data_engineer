   "source": [
    "## read file using With open()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "34fcd850-ad13-4b33-b34a-e0d19a899a26",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "hello\n",
      "This is python\n",
      "I love python very much\n"
     ]
    }
   ],
   "source": [
    "with open(\"hello.txt\") as file:\n",
    "    print(file.read())"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "ce2b8bf6-2075-4301-9b82-08b07a9c7cb8",
   "metadata": {},
   "source": [
    "# write"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "d22bab05-3e04-4cb2-83d8-6f9e2bf8e646",
   "metadata": {},
   "outputs": [],
   "source": [
    "with open(\"abc.txt\",\"w\") as file:\n",
    "    file.write(\"hello\\nThis Is python\\nGood day\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "bc637239-d662-4e82-96de-13b357ce6254",
   "metadata": {},
   "source": [
    "# Append"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "0c74a3dc-017a-4a80-a3ab-c4aaea234ccc",
   "metadata": {},
   "outputs": [],
   "source": [
    "with open(\"abc.txt\",\"a\") as file:\n",
    "    file.write(\"append\")"
   ]
  }
